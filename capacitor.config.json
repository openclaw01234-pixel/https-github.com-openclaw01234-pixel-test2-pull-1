{
  "appId": "com.mxplayer.pro",
  "appName": "MX Player Pro",
  "webDir": "www",
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#0a0a0f",
      "showSpinner": false
    }
  },
  "server": {
    "androidScheme": "https"
  }
}
