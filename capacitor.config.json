{
  "appId": "com.mxplayer.pro.web",
  "appName": "MX Player Pro",
  "webDir": ".",
  "bundledWebRuntime": false,
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0a0a0f",
      "showSpinner": false
    }
  },
  "server": {
    "androidScheme": "https",
    "cleartext": true
  }
}
